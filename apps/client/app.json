{
	"expo": {
		"name": "uni",
		"slug": "uni",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "uni",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"usesAppleSignIn": true,
			"bundleIdentifier": "me.lockie.uni",
			"appleTeamId": "727YJTPFCL",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			},
			"entitlements": {
				"com.apple.developer.applesignin": true
			}
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/adaptive-icon.png",
				"backgroundColor": "#ffffff"
			},
			"edgeToEdgeEnabled": true,
			"permissions": [
				"android.permission.RECORD_AUDIO",
				"android.permission.MODIFY_AUDIO_SETTINGS",
				"android.permission.READ_EXTERNAL_STORAGE",
				"android.permission.WRITE_EXTERNAL_STORAGE",
				"android.permission.DOWNLOAD_WITHOUT_NOTIFICATION",
				"android.permission.ACCESS_NETWORK_STATE",
				"android.permission.RECORD_AUDIO",
				"android.permission.MODIFY_AUDIO_SETTINGS",
				"android.permission.READ_EXTERNAL_STORAGE",
				"android.permission.WRITE_EXTERNAL_STORAGE",
				"android.permission.DOWNLOAD_WITHOUT_NOTIFICATION",
				"android.permission.ACCESS_NETWORK_STATE"
			],
			"package": "me.lockie.uni"
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff"
				}
			],
			"expo-audio",
			[
				"@react-native-google-signin/google-signin",
				{
					"iosUrlScheme": "com.googleusercontent.apps.456406260871-794k1s0indqadv5l1klvbbmrargofh19"
				}
			],
			"expo-localization",
			[
				"expo-asset",
				{
					"assets": [
						"./assets/images/user.jpg",
						"./assets/images/uni_cover.png",
						"./assets/images/uni_cover.mp4"
					]
				}
			],
			"expo-font",
			"expo-web-browser",
			"expo-apple-authentication",
			[
				"expo-video",
				{
					"supportsBackgroundPlayback": false,
					"supportsPictureInPicture": false
				}
			],
			[
				"@siteed/expo-audio-studio",
				{
					"enableBackgroundAudio": false,
					"enablePhoneStateHandling": false,
					"enableNotifications": false,
					"enableDeviceDetection": false,
					"iosBackgroundModes": {
						"useVoIP": false,
						"useAudio": false,
						"useProcessing": false,
						"useLocation": false,
						"useExternalAccessory": false
					},
					"iosConfig": {
						"allowBackgroundAudioControls": false
					}
				}
			],
			"react-native-legal"
		],
		"experiments": {
			"typedRoutes": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "a2adfebf-ba97-4fa7-9638-3bdd51ffaaba"
			}
		},
		"runtimeVersion": {
			"policy": "appVersion"
		},
		"updates": {
			"url": "https://u.expo.dev/a2adfebf-ba97-4fa7-9638-3bdd51ffaaba"
		}
	}
}
