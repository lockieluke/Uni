[
  {
    "label": "iOS",
    "command": "bun ios",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "shell": "system"
  },
  {
    "label": "Start Expo Dev Server",
    "command": "bun start",
    "shell": "system",
    "hide": "on_success",
    "use_new_terminal": false,
    "allow_concurrent_runs": false
  },
  {
    "label": "Reset watchman",
    "command": "watchman watch-del '$ZED_WORKTREE_ROOT'; watchman watch-project '$ZED_WORKTREE_ROOT'",
    "shell": "system",
    "cwd": "$ZED_WORKTREE_ROOT",
    "hide": "on_success",
    "use_new_terminal": false,
    "allow_concurrent_runs": false
  }
]
