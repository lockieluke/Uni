[
	{
		"label": "iOS",
		"command": "bun ios",
		"use_new_terminal": false,
		"allow_concurrent_runs": false,
		"hide": "on_success",
		"cwd": "$ZED_WORKTREE_ROOT/apps/client"
	},
	{
		"label": "Start Expo Dev Server",
		"command": "bun start",
		"hide": "on_success",
		"use_new_terminal": false,
		"allow_concurrent_runs": false,
		"cwd": "$ZED_WORKTREE_ROOT/apps/client"
	},
	{
		"label": "Reset watchman",
		"command": "watchman watch-del '$ZED_WORKTREE_ROOT'; watchman watch-project '$ZED_WORKTREE_ROOT'",
		"cwd": "$ZED_WORKTREE_ROOT",
		"hide": "on_success",
		"use_new_terminal": false,
		"allow_concurrent_runs": false
	},
	{
		"label": "Lint",
		"command": "bun lint",
		"cwd": "$ZED_WORKTREE_ROOT",
		"hide": "on_success",
		"use_new_terminal": false,
		"allow_concurrent_runs": false
	},
	{
		"label": "Start wrangler Dev Server",
		"command": "bun dev",
		"hide": "on_success",
		"use_new_terminal": false,
		"allow_concurrent_runs": false,
		"cwd": "$ZED_WORKTREE_ROOT/apps/worker",
		"env": {
			"WRANGLER_SEND_METRICS": "false"
		}
	},
	{
		"label": "Start cloudflared tunnel",
		"command": "cloudflared tunnel --url http://localhost:8787",
		"hide": "on_success",
		"use_new_terminal": false,
		"allow_concurrent_runs": false
	}
]
